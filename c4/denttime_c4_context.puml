@startuml denttime_c4_context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title [System Context Diagram] DentTime - AI-Powered Smart Dentist Scheduling System

' ===== Primary Users =====
Person(clinicStaff, "Clinic Staff", "Dental clinic staff.\nAccepts queue bookings and fills patient\nsymptoms to schedule appointments.")

Person_Ext(dentist, "Dentist", "Reviews balanced schedule.\nBenefits from accurate time slots\nreducing overtime and gap time.")

Person_Ext(clinicAdmin, "Clinic Administrator", "Monitors clinic performance.\nTracks waiting time reduction\nand resource utilization across branches.")

' ===== Core System =====
System(denttime, "DentTime System", "AI-Powered Smart Dentist Scheduling System.\nDecision Support System (DSS) that predicts\nsuitable treatment duration (Suggestion Time Window)\nvia Online Prediction (p99 < 1s).\nClassifies into 7 slots: 15/30/45/60/75/90/105 min.")

' ===== External Systems =====
System_Ext(cms, "Clinic Management System (CMS)", "Source of historical appointment\nand treatment records.\nMySQL/PostgreSQL database.\nProvides ~1,000,000 records (2025).")

System_Ext(gcs, "Google Cloud Storage", "Cloud Storage Service.\nStores Versioned ONNX Models\nin Triton Model Repository format.")

System_Ext(gke, "Google Kubernetes Engine\n(GKE Autopilot)", "Managed Kubernetes Platform.\nSupports Auto-scaling for\nProduction Deployment.")

' ===== Relationships =====
Rel(clinicStaff, denttime, "Fills patient symptoms\nand receives predicted time window", "HTTPS")
Rel(dentist, denttime, "Views scheduled time slots\nand workload summary", "HTTPS")
Rel(clinicAdmin, denttime, "Monitors scheduling efficiency\nand system performance", "HTTPS")

Rel(cms, denttime, "Provides historical appointment\nand treatment records", "SQL / CSV Export")
Rel(denttime, gcs, "Loads/Updates versioned\nML model artifacts", "GCS API")
Rel(denttime, gke, "Deployed and auto-scaled on", "Kubernetes")

@enduml
