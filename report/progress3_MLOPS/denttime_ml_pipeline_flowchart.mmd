%%{init: {'theme': 'base', 'themeVariables': {'fontSize': '13px'}}}%%
flowchart TD

    %% ─────────────────────────────────────────────
    %% COLOR LEGEND
    %% 🟢 Automatic  — fully scheduled, no human trigger
    %% 🔵 Semi-auto  — Airflow-managed, some manual setup
    %% 🟠 Manual     — human must run / decide each time
    %% ⚫ Future     — planned, not yet implemented
    %% ─────────────────────────────────────────────
    classDef automatic  fill:#16a34a,stroke:#14532d,color:#ffffff,font-weight:bold
    classDef semiauto   fill:#2563eb,stroke:#1e3a8a,color:#ffffff,font-weight:bold
    classDef manual     fill:#ea580c,stroke:#7c2d12,color:#ffffff,font-weight:bold
    classDef future     fill:#6b7280,stroke:#374151,color:#ffffff,font-weight:bold
    classDef decision   fill:#7c3aed,stroke:#4c1d95,color:#ffffff,font-weight:bold

    %% ═══════════════════════════════════════
    %%  PHASE 1 — DATA
    %% ═══════════════════════════════════════
    subgraph DATA["① DATA"]
        direction TB
        D1[("🗄️ CMS Database MySQL / PostgreSQL Historical Appointments ~1M records / year")]
        D2["🔍 SQL Query + CSV Export DBA access required"]
        D3["🔐 SHA-256 Anonymization doctor_license_no hashing Airflow DAG"]
        D4["✅ Data Validation Schema · Missing rate Distribution check Great Expectations"]
        D5["🧹 Data Cleaning Missing Data · Fuzzy Match Dictionary Mapping · Outlier Removal Airflow"]
        D6["⚙️ Feature Engineering Treatment Class · Tooth Count Time of Day · Is First Case Doctor Profile Stats Pandas + RapidFuzz + Airflow"]
        D7[("📦 Feature Store Apache Parquet DVC versioned")]
    end

    %% ═══════════════════════════════════════
    %%  PHASE 2 — TRAINING
    %% ═══════════════════════════════════════
    subgraph TRAIN["② TRAINING"]
        direction TB
        T1["🔀 Chronological Data Split Train: Month 1–10 Validation: Month 11 Test: Month 12"]
        T2["📊 Doctor Profile Stats Calculated from Train Set only Cold-start → Global Median fallback"]
        T3["⚡ XGBoost Training class_weight · HP tuning Grid / Random Search on Val Set MLFlow"]
        T5["📝 Experiment Tracking Metrics · Confusion Matrix Feature Importance · HP log MLFlow"]
    end

    %% ═══════════════════════════════════════
    %%  PHASE 3 — EVALUATION
    %% ═══════════════════════════════════════
    subgraph EVAL["③ EVALUATION"]
        direction TB
        E1["📈 Offline Evaluation on Test Set ① Macro F1-score ② Under-estimation Rate ③ MAE (minutes) MLFlow"]
        E2{"🏆 New model better than current?"}
        E3["📦 Model Registry Joblib → ONNX format denttime_xgb_v1.0_202501.pkl GCS Bucket · MLFlow versioning"]
        E4["🗄️ Archive Old Model Keep 2 previous versions as Fallback + Metadata JSON MLFlow"]
    end

    %% ═══════════════════════════════════════
    %%  PHASE 4 — DEPLOYMENT
    %% ═══════════════════════════════════════
    subgraph DEPLOY["④ DEPLOYMENT"]
        direction TB
        DEP1["👻 Shadow Deployment New model runs in background Mirrored real traffic Result NOT returned to user KServe Shadow Mode"]
        DEP2{"Shadow eval passed?"}
        DEP3["🐤 Canary Release 10% traffic → new model Gradual rollout to 100% KServe Traffic Routing"]
        DEP4["🔌 FastAPI + Docker ML Inference Service Online Prediction · p99 < 1s Manual model swap"]
        DEP5["☸️ Production Scale KServe + Triton Inference Server GKE Autopilot · Auto-scaling HPA/VPA"]
        DEP6["🌐 React Web App DentTime UI Clinic Staff fills symptoms → Suggested Time Window"]
    end

    %% ═══════════════════════════════════════
    %%  PHASE 5 — MONITORING (DATA DIFF)
    %% ═══════════════════════════════════════
    subgraph MONITOR["⑤ MONITORING · DATA DIFF"]
        direction TB
        M1["📡 Operational Metrics Inference Latency · Throughput (RPS) API Error Rate · CPU/Memory Model Staleness Prometheus"]
        M_DRIFT["🌊 Drift Detection Output Distribution shift (Class 15–105 min) Feature Drift via PSI · threshold > 0.25   └ Rolling 7-day · Monthly cumulative Multivariate Drift via MMD"]
        M_PERF["📋 Performance Metrics Weekly Airflow DAG JOIN prediction_log + CMS actuals ON appointment_id → Macro F1 · MAE · Under-estimation Rate → Push to Prometheus gauge"]
        M6["⚠️ Early Warning Signals User Override frequency Doctor complaints · Patient wait anomaly System Logs"]
        M7{"🚨 Retrain Trigger?"}
    end

    %% ═══════════════════════════════════════
    %%  MAIN FLOW CONNECTIONS
    %% ═══════════════════════════════════════
    D1 --> D2 --> D3 --> D4 --> D5 --> D6 --> D7
    D7 --> T1
    T1 --> T2
    T2 --> T3
    T3 --> T5
    T5 --> E1
    E1 --> E2
    E2 -- "✅ Yes → promote" --> E3
    E2 -- "❌ No → investigate & tune" --> T3
    E3 --> E4
    E3 --> DEP1
    DEP1 --> DEP2
    DEP2 -- "✅ Pass" --> DEP3
    DEP2 -- "❌ Fail → rollback" --> E4
    DEP3 --> DEP4
    DEP4 --> DEP5
    DEP4 --> DEP6
    DEP4 --> M1
    DEP6 --> M_DRIFT
    DEP4 --> M_DRIFT
    DEP4 -->|"logs predictions (appointment_id + predicted_slot)"| M_PERF
    D1 -->|"actual durations (receipt_time - check_in_time)"| M_PERF
    M6 -.->|"indirect signal"| M7
    M1 & M_DRIFT & M_PERF --> M7
    M7 -- "🔄 Yes → retrain\n(time/perf/drift/event)" --> D1

    %% ═══════════════════════════════════════
    %%  APPLY STYLES
    %% ═══════════════════════════════════════

    %% 🟠 MANUAL
    class D2 manual
    class T3,T4,T5,E1,E4 manual
    class DEP4,DEP6 manual
    class M1,M_PERF manual

    %% 🔵 SEMI-AUTO
    class D3,D5,D6 semiauto
    class T1,T2 semiauto
    class E3 semiauto

    %% 🟢 AUTOMATIC
    class D1,D7 automatic

    %% ⚫ FUTURE
    class D4 future
    class DEP1,DEP2,DEP3,DEP5 future
    class M_DRIFT,M6,M7 future

    %% 🟣 DECISION
    class E2,DEP2,M7 decision
