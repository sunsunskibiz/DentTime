%%{init: {'theme': 'base', 'themeVariables': {'fontSize': '13px'}}}%%
flowchart TD

    %% ─────────────────────────────────────────────
    %% COLOR LEGEND
    %% 🟢 Data Source   — raw inputs
    %% 🔵 Processing    — detection / computation nodes
    %% 🟣 Signal        — drift signal outputs
    %% 🔴 Action        — retrain trigger & alerting
    %% 🟠 Alerting      — observability outputs
    %%
    %% READ ORDER: follow step numbers ① → ⑭
    %% ─────────────────────────────────────────────
    classDef datasource  fill:#16a34a,stroke:#14532d,color:#ffffff,font-weight:bold
    classDef processing  fill:#2563eb,stroke:#1e3a8a,color:#ffffff,font-weight:bold
    classDef signal      fill:#7c3aed,stroke:#4c1d95,color:#ffffff,font-weight:bold
    classDef action      fill:#dc2626,stroke:#7f1d1d,color:#ffffff,font-weight:bold
    classDef alerting    fill:#ea580c,stroke:#7c2d12,color:#ffffff,font-weight:bold

    %% ═══════════════════════════════════════
    %%  STEP 1 — SINGLE DATA SOURCE
    %% ═══════════════════════════════════════
    D1[("① 🗄️ CMS Database D1 [START HERE]")]
    D7[("⑥ 📦 D7: Feature Store Training Reference Distribution")]

    D1 --> LAF["② 📡 Live Appointment Feed"]

    %% ═══════════════════════════════════════
    %%  BRANCH A — SIGNAL 1: DATA QUALITY DRIFT
    %%  Steps ③ → ④
    %% ═══════════════════════════════════════
    LAF -->|"Branch A"| D4["③ ✅ D4: Great Expectations schema · null rate value range checks"]
    D4 --> S1(["④ ⚠️ SIGNAL 1 Data Quality Drift Score"])

    %% ═══════════════════════════════════════
    %%  BRANCH B — SIGNAL 2 + 3: FEATURE & OUTPUT DRIFT
    %%  Steps ⑤ → ⑨
    %% ═══════════════════════════════════════
    LAF -->|"Branch B"| DEP4["⑤ 🔌 DEP4: FastAPI logs prediction appointment_id + predicted_slot"]

    D7 --> S2(["⑦ 📊 SIGNAL 2 Feature Drift PSI per feature MMD multivariate"])

    DEP4 --> MDRIFT["⑧ 🌊 M_DRIFT Distribution Shift Detector"]
    S2   --> MDRIFT

    MDRIFT --> S3(["⑨ 📉 SIGNAL 3: Output Drift class ratios 15 / 30 / 45 / 60 / 75 / 90 min"])

    %% ═══════════════════════════════════════
    %%  SIGNAL 4 — CONCEPT DRIFT
    %%  Steps ⑩ → ⑪  (merges Branch A + B results)
    %% ═══════════════════════════════════════
    MPERF["⑩ 📋 M_PERF: JOIN actuals receipt_time − check_in_time"]
    D1 -->|"actual durations"| MPERF

    S3    --> S4(["⑪ 🚨 SIGNAL 4: Concept Drift F1 · MAE · Under-est Rate"])
    MPERF --> S4

    %% ═══════════════════════════════════════
    %%  RETRAIN TRIGGER & ALERTING
    %%  Steps ⑫ → ⑭
    %% ═══════════════════════════════════════
    S1 --> M7{"⑫ 🔄 M7: Retrain Trigger threshold logic"}
    S4 --> M7

    M7 --> PROM["⑬ 📈 Prometheus Gauges denttime_macro_f1_gauge denttime_under_estimation_rate_gauge denttime_mae_minutes_gauge"]
    PROM --> GRAF["⑭ 🔔 Grafana Alerts Alerting Rules + Dashboard"]

    M7 -->|"trigger retrain"| RETRAIN(["♻️ Retrain Pipeline"])

    %% ═══════════════════════════════════════
    %%  APPLY STYLES
    %% ═══════════════════════════════════════
    class D1,D7 datasource
    class LAF,D4,DEP4,MDRIFT,MPERF processing
    class S1,S2,S3,S4 signal
    class M7,RETRAIN action
    class PROM,GRAF alerting
