@startuml denttime_c4_container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title [Container Diagram] DentTime - AI-Powered Smart Dentist Scheduling System\n(ML Pipeline + Serving Architecture)

' ===== Legend Notes =====
' [Semi-auto] = partially automated via Airflow
' [Manual]    = currently run manually / via Jupyter
' [Partial]   = implemented but incomplete
' [Not started] = planned, not yet built

' ===== External Actors =====
Person(clinicStaff, "Clinic Staff", "Accepts queue bookings.\nFills patient symptoms to\nschedule appointments.")

System_Ext(cms, "Clinic Management System (CMS)", "Source of raw historical appointment\nand treatment records.\nMySQL / PostgreSQL database.\n~1,000,000 records (2025).")

System_Ext(gkeAutopilot, "GKE Autopilot (Future)", "Managed Kubernetes platform.\nAuto-scales inference pods.\nTarget for production deployment.")

' ===== DentTime System Boundary =====
System_Boundary(denttime, "DentTime System") {

    ' ─── Stage 1: Data Ingestion [Semi-auto / 4 pts] ───
    Container(dataIngestion, "Data Ingestion Pipeline", "MySQL + Apache Airflow DAG\n+ SHA-256 Anonymization", "[Semi-auto | 4 pts]\nExtracts selected columns from CMS via SQL.\nApplies SHA-256 hashing on doctor_license_no.\nOutputs: Anonymized Parquet files.")

    ' ─── Stage 2: Data Validation [Manual / 2 pts] ───
    Container(dataValidation, "Data Validation", "Jupyter Notebook\n→ Great Expectations (future)", "[Manual | 2 pts]\nChecks schema, missing rates,\noutlier bounds, and distribution.\nFuture: automated schema drift detection\nand distribution shift alerts.")

    ' ─── Stage 3: Feature Engineering [Semi-auto / 5 pts] ───
    Container(featureEng, "Feature Engineering Pipeline", "Pandas + RapidFuzz\n+ Dictionary Mapping + Airflow", "[Semi-auto | 5 pts]\nHandles missing data, free-text noisy fields.\nFuzzy match + Dictionary mapping → Treatment Class.\nOutlier removal (Duration > 105 min or < 5 min).\nEngineers: Treatment Class, Tooth Count, Tooth Scope,\nComposite Treatment Flag, Time of Day,\nIs First Case, Doctor Profile Features\n(doctor_median_duration, doctor_case_volume,\ndoctor_speed_ratio — computed from Training Set only).\nOutputs: Feature Store (versioned Parquet).")

    ' ─── Shared Data Stores ───
    ContainerDb(rawParquet, "Anonymized Raw Data", "Apache Parquet", "Anonymized appointment records.\nRetained before feature engineering.")

    ContainerDb(featureStore, "Feature Store", "Apache Parquet (versioned)", "Cleaned, feature-engineered dataset.\nVersioned: v1 (basic clean), v2 (+ rules/validation).\nUsed as input for Model Training.")

    ' ─── Stage 4: Model Training [Manual / 5 pts] ───
    Container(modelTraining, "Model Training", "XGBoost + scikit-learn + MLflow", "[Manual | 5 pts]\nChronological split: Train(M1–10) / Val(M11) / Test(M12).\nTrains XGBoost (primary) and Random Forest (fallback).\nHyperparameter tuning via Grid/Random Search on Val Set.\nEarly Stopping on Validation Set.\nClass weights (balanced) for minority classes.\nDoctor Profile Stats computed from Training Set only.\nOutputs: Trained model artifact (.pkl / Joblib).")

    ' ─── Stage 5: Model Evaluation [Manual / 3 pts] ───
    Container(modelEval, "Model Evaluation", "MLflow — Macro F1, Under-est. Rate\nMAE, Confusion Matrix", "[Manual | 3 pts]\nEvaluates on Test Set (Month 12).\nPrimary metric: Macro F1 (all 7 classes equal weight).\nBusiness metric: Under-estimation Rate.\nSecondary: MAE (minutes), Huber Loss.\nDiagnostic: Per-class Precision/Recall,\nConfusion Matrix (adjacent class errors).\nOutputs: Evaluation Report in MLflow.")

    ' ─── Stage 6: Model Registry [Partial / 1 pt] ───
    ContainerDb(modelRegistry, "Model Registry", "Joblib + MLflow versioning\n→ ONNX format (GCS)", "[Partial | 1 pt]\nVersioned model artifacts with metadata:\nTraining Period, Feature Set Version,\nHyperparameters, Dictionary Version, Metrics.\nNaming: denttime_xgb_v{MAJOR}.{MINOR}_{YYYYMM}.pkl\nRetains last 2 versions as Fallback.\nApproved models exported to ONNX for serving.")

    ' ─── Stage 7: Model Serving / API [Partial / 3 pts] ───
    Container(modelServing, "Model Serving / API", "FastAPI + Docker\n[Current — Partial]\n→ KServe + Triton Inference Server [Future]", "[Partial | 3 pts]\nCurrent: FastAPI + Docker container.\nLoads .pkl model, serves via REST endpoint.\nOn-demand Online Prediction (p99 target < 3s current,\n< 1s target with KServe + Triton).\nFuture: Export to ONNX, deploy via KServe on GKE\nwith Shadow/Canary deployment strategy.")

    ' ─── Stage 8: UI / Web Application [Not started / 4 pts] ───
    Container(webApp, "UI / Web Application", "React / Next.js + HTTPS / JSON\n[NOT STARTED]", "[Not started | 4 pts]\nFrontend for queue booking.\nClinic staff fills patient symptoms.\nDisplays Suggested Time Window\nreturned from Backend API.")

    ' ─── Stage 9: Monitoring & Alerting [Not started / 3 pts] ───
    Container(monitoring, "Monitoring & Alerting", "Grafana + Prometheus\n[NOT STARTED]", "[Not started | 3 pts]\nTracks: Inference Latency, RPS, API Error Rate,\nCPU/Memory Utilization, Model Staleness.\nDrift Detection:\n- PSI (7-day rolling + monthly cumulative)\n- MMD (multivariate distribution shift)\n- Output Drift (prediction class distribution)\nBusiness Metrics: Under-estimation Rate,\nSchedule Adherence, Gap Time, Overtime.\nTriggers Retrain: F1 drop > 5%, PSI > 0.25.")
}

' ===== Relationships — Training Pipeline (Offline / Batch) =====
Rel(cms, dataIngestion, "Raw appointment &\ntreatment records", "SQL Query / CSV Export")
Rel(dataIngestion, rawParquet, "Writes anonymized\nParquet files", "File I/O")
Rel(rawParquet, dataValidation, "Reads raw Parquet\nfor validation", "File I/O")
Rel(dataValidation, featureEng, "Passes validated\ndataset", "File I/O")
Rel(featureEng, featureStore, "Writes versioned\nfeature Parquet", "File I/O")
Rel(featureStore, modelTraining, "Reads training\nfeature set", "File I/O")
Rel(modelTraining, modelEval, "Passes trained\nmodel artifact (.pkl)", "Joblib")
Rel(modelEval, modelRegistry, "Registers approved model\nwith metrics metadata", "MLflow API")

' ===== Relationships — Serving Pipeline (Online / On-demand) =====
Rel(modelRegistry, modelServing, "Loads versioned model\n(.pkl → ONNX for future)", "File Load / GCS API")
Rel(webApp, modelServing, "Sends booking request\nwith patient features", "HTTPS / JSON")
Rel(modelServing, webApp, "Returns Suggested\nTime Window\n(one of: 15/30/45/60/75/90/105 min)", "JSON Response")
Rel(clinicStaff, webApp, "Fills patient symptoms\nand views prediction", "HTTPS")

' ===== Relationships — Monitoring =====
Rel(modelServing, monitoring, "Emits latency, throughput\nand prediction logs", "Prometheus metrics")
Rel(monitoring, modelTraining, "Triggers Retrain on\ndrift/performance alert", "Webhook / Manual")
Rel(modelServing, gkeAutopilot, "Future: Auto-scale\ninference pods on", "Kubernetes HPA/KPA")

@enduml
